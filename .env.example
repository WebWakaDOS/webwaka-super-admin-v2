# =============================================================================
# WebWaka Super Admin V2 — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or any file containing real secrets.
# =============================================================================

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Base URL of the Hono Workers API (no trailing slash)
# Local dev:   http://localhost:8787
# Staging:     https://webwaka-super-admin-api-staging.webwaka.workers.dev
# Production:  https://webwaka-super-admin-api.webwaka.workers.dev
VITE_API_URL=http://localhost:8787

# App environment (development | staging | production)
VITE_APP_ENV=development

# Default locale (en | yo | ig | ha)
VITE_DEFAULT_LOCALE=en

# Sentry DSN for frontend error tracking (optional)
VITE_SENTRY_DSN=

# ── Workers (set via Cloudflare Dashboard or wrangler secret put) ─────────────
# These MUST be set as Cloudflare Worker Secrets — never hardcode them.
# Use: wrangler secret put <SECRET_NAME>

# JWT signing secret — minimum 32 characters, cryptographically random
# Generate: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_RANDOM_32_CHAR_HEX

# ── Cloudflare resource IDs ───────────────────────────────────────────────────
# Obtain via: wrangler d1 list | wrangler kv:namespace list
# These are already in wrangler.toml; only needed for direct CLI usage.

# CF_ACCOUNT_ID=your-cloudflare-account-id
# RBAC_DB_ID=<uuid from wrangler d1 create rbac_staging>
# TENANTS_DB_ID=<uuid from wrangler d1 create tenants_staging>
# BILLING_DB_ID=<uuid from wrangler d1 create billing_staging>
# HEALTH_DB_ID=<uuid from wrangler d1 create health_staging>
# SESSIONS_KV_ID=<uuid from wrangler kv:namespace create sessions_staging>
# CACHE_KV_ID=<uuid from wrangler kv:namespace create cache_staging>
# FEATURE_FLAGS_KV_ID=<uuid from wrangler kv:namespace create feature_flags_staging>

# ── E2E / Playwright ──────────────────────────────────────────────────────────
# Only needed when running Playwright tests locally or in CI.
# Playwright reads PLAYWRIGHT_BASE_URL and TEST_ADMIN_* vars at test time.

# URL of the running app (must be started before running Playwright)
# Local: http://localhost:5175  (must match `cd frontend && pnpm dev --port 5175`)
# Staging: https://webwaka-super-admin-ui.pages.dev
PLAYWRIGHT_BASE_URL=http://localhost:5175

# Seed credentials (match workers/migrations/seed/rbac.sql)
# Local only — DO NOT use production credentials here
TEST_ADMIN_EMAIL=superadmin@webwaka.dev
TEST_ADMIN_PASSWORD=WebWaka@2025!

# ── Local development quick-start ────────────────────────────────────────────
# 1. Install deps:         pnpm install
# 2. Copy env:             cp .env.example frontend/.env.local
# 3. Apply D1 migrations:  cd workers && wrangler d1 migrations apply rbac_staging --local
# 4. Seed local DBs:       node workers/scripts/seed-local.mjs
# 5. Start Workers API:    cd workers && wrangler dev --port 8787
# 6. Start frontend:       cd frontend && pnpm dev (separate terminal)
# 7. Run unit tests:       cd workers && pnpm test
# 8. Run E2E tests:        cd frontend && pnpm exec playwright test
