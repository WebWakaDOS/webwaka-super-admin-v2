# =============================================================================
# WebWaka Super Admin V2 — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or any file containing real secrets.
# =============================================================================

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Base URL of the Hono Workers API (no trailing slash)
# Local dev: http://localhost:8787
# Staging:   https://webwaka-super-admin-api-staging.webwaka.workers.dev
# Production: https://webwaka-super-admin-api.webwaka.workers.dev
VITE_API_URL=http://localhost:8787

# App environment (development | staging | production)
VITE_APP_ENV=development

# Sentry DSN for frontend error tracking (optional)
VITE_SENTRY_DSN=

# ── Workers (set via Cloudflare Dashboard or wrangler secret put) ─────────────
# bcrypt-compatible password hashing is done inside the Worker.
# These must be set as Cloudflare Secrets — do NOT hardcode them here.

# JWT signing secret (min 32 chars, cryptographically random)
# Generate: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_RANDOM_32_CHAR_HEX

# ── Cloudflare Resource IDs (staging — from wrangler.toml) ───────────────────
# These are already in wrangler.toml; only needed for direct wrangler CLI usage.
# CF_ACCOUNT_ID=your-cloudflare-account-id

# ── Local development ─────────────────────────────────────────────────────────
# Start frontend:  cd frontend && pnpm dev
# Start Workers:   cd workers && pnpm wrangler dev --port 8787
# Apply migrations: wrangler d1 migrations apply rbac_staging --local
